{
  "name": "accpocket",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @accpocket/web --filter @accpocket/api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @accpocket/api prisma generate",
    "db:migrate": "pnpm --filter @accpocket/api prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @accpocket/api prisma migrate deploy",
    "db:seed": "pnpm --filter @accpocket/api prisma db seed"
  },
  "devDependencies": { "typescript": "^5.8.3" }
}
